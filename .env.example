# Copy to .env and fill in real values:
#   cp .env.example .env
# Never commit .env.

# --- Weights & Biases ---
# Get a key at https://wandb.ai/authorize
WANDB_API_KEY=

# Optional overrides (CLI --wandb_project / --wandb_entity also work)
WANDB_PROJECT=FewRel
# WANDB_ENTITY=your-team-or-username

# online | offline | disabled
WANDB_MODE=online
# WANDB_DISABLED=1
# WANDB_DIR=./wandb

# --- Hugging Face (LLM encoder / gated models) ---
# Create at https://huggingface.co/settings/tokens
# HF_TOKEN=
# HUGGINGFACE_HUB_TOKEN=
# HF_HOME=./.hf_cache

# --- Runtime (optional) ---
# CUDA_VISIBLE_DEVICES=0
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
